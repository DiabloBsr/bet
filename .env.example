# URL de la page à observer (obligatoire)
TARGET_URL=https://example.com/virtual-sports

# Intervalle entre deux collectes, en secondes
SCRAPE_INTERVAL_SECONDS=180

# Bruit ajouté à l'intervalle (±N secondes) pour ne pas être prévisible
JITTER_SECONDS=15

# Connexion base — SQLite par défaut ; postgresql+psycopg://... pour PG
DB_URL=sqlite:///./data/virtual_sports.db

# Logs
LOG_LEVEL=INFO
LOG_FILE=./logs/scraper.log

# Playwright
HEADLESS=true
PAGE_TIMEOUT_MS=30000
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
